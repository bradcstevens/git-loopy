# macOS
.DS_Store

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files
.env
.env.local
.env.*.local

# Node (kept so this template is safe to scaffold a Node app into)
node_modules/
dist/
build/
coverage/
.nyc_output/

# Python (kept so this template is safe to scaffold a Python app into)
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.python-version
*.egg-info/

# Ralph runtime
copiloop/.tmp/
.ralph-grill.lock
.ralph/

# copiloop/python/ persisted observability artefacts (JSONL event logs +
# per-run summary JSONs; never commit).
.copiloop/

# Project-local PRDs and issues for the legacy ISSUE_SOURCE=prds mode.
# GitHub Issues is the default in this kit; uncomment the lines below if you
# want to track local markdown issues in version control instead.
prds/
issues/

# Copilot CLI session state (per-session artifacts; never commit)
.copilot/session-state/
.pytest_cache/
.ruff_cache/

# Intake feature-request briefs (per-run capture from /intake; not tracked)
docs/feature-requests/
